# Terraform working directory
.terraform/

# Backend config files
backend.hcl

# Terraform state files 
*.tfstate
*.tfstate.*

# Crash logs
crash.log

# Exclude all .tfvars files (often contain secrets)
*.tfvars
*.tfvars.json

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI configuration files
.terraformrc
terraform.rc

# Sensitive plan output files
*.tfplan

# Lock file (optional: usually COMMIT this for consistency)
# .terraform.lock.hcl

# Ignore local environment files
.env
.env.*

# OS-specific files
.DS_Store
Thumbs.db

# Editor/IDE files
.vscode/
.idea/
*.swp